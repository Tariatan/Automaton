<Window x:Class="Automaton.MainWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Automaton"
        Topmost="True" ResizeMode="NoResize" Height="120" Width="251" WindowStyle="ToolWindow" Background="{DynamicResource {x:Static SystemColors.DesktopBrushKey}}">
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0"
              Margin="0,0,0,2"
              VerticalAlignment="Top">
            <MenuItem Header="Settings">
                <MenuItem x:Name="DebugMenuItem"
                          Header="Debug"
                          IsCheckable="True"
                          IsChecked="True" />
                <MenuItem x:Name="TelemetryMenuItem"
                          Header="Telemetry"
                          Click="TelemetryMenuItem_Click" />
                <MenuItem x:Name="HallmarkMenuItem"
                          Header="Hallmark"
                          Click="HallmarkMenuItem_Click" />
                <Separator />
                <MenuItem x:Name="SettingsDiscoveryModeMenuItem"
                          Header="Discovery"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="SettingsDiscoveryModeMenuItem_Click" />
                <MenuItem x:Name="SettingsMiningModeMenuItem"
                          Header="Mining"
                          IsCheckable="True"
                          Click="SettingsMiningModeMenuItem_Click" />
            </MenuItem>
            <MenuItem x:Name="DiscoveryMenuItem"
                      Header="Discovery">
                <MenuItem x:Name="DiscoveryStartingGameMenuItem" Header="StartingGame" IsCheckable="True" IsChecked="True" Click="DiscoveryStartingGameMenuItem_Click" />
                <MenuItem x:Name="DiscoveryLoginMenuItem" Header="Login" IsCheckable="True" Click="DiscoveryLoginMenuItem_Click" />
                <MenuItem x:Name="DiscoveryDiscoverMenuItem" Header="Discover" IsCheckable="True" Click="DiscoveryDiscoverMenuItem_Click" />
                <MenuItem x:Name="DiscoveryRecoveryMenuItem" Header="Recovery" IsCheckable="True" Click="DiscoveryRecoveryMenuItem_Click" />
                <MenuItem x:Name="DiscoveryRecoverSlowDownPopupMenuItem" Header="RecoverSlowDownPopup" IsCheckable="True" Click="DiscoveryRecoverSlowDownPopupMenuItem_Click" />
                <MenuItem x:Name="DiscoveryRecoverConnectionLostPopupMenuItem" Header="RecoverConnectionLostPopup" IsCheckable="True" Click="DiscoveryRecoverConnectionLostPopupMenuItem_Click" />
                <MenuItem x:Name="DiscoveryRecoverMaxSubmissionsPopupMenuItem" Header="RecoverMaxSubmissionsPopup" IsCheckable="True" Click="DiscoveryRecoverMaxSubmissionsPopupMenuItem_Click" />
                <Separator />
                <MenuItem x:Name="Pilot1MenuItem"
                          Header="Pilot 1"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="Pilot1MenuItem_Click" />
                <MenuItem x:Name="Pilot2MenuItem"
                          Header="Pilot 2"
                          IsCheckable="True"
                          Click="Pilot2MenuItem_Click" />
                <MenuItem x:Name="Pilot3MenuItem"
                          Header="Pilot 3"
                          IsCheckable="True"
                          Click="Pilot3MenuItem_Click" />
                <Separator />
                <MenuItem x:Name="SamplesMenuItem"
                          Header="Samples"
                          Click="Samples_Click" />
                <MenuItem x:Name="ExtractTrainingMenuItem"
                          Header="Extract Training"
                          Click="ExtractTraining_Click" />
            </MenuItem>
            <MenuItem x:Name="MiningMenuItem"
                      Header="Mining">
                <MenuItem x:Name="MiningStartingGameMenuItem" Header="StartingGame" IsCheckable="True" IsChecked="True" Click="MiningStartingGameMenuItem_Click" />
                <MenuItem x:Name="MiningLoginMenuItem" Header="Login" IsCheckable="True" Click="MiningLoginMenuItem_Click" />
                <MenuItem x:Name="MiningUnloadCargoMenuItem" Header="UnloadCargo" IsCheckable="True" Click="MiningUnloadCargoMenuItem_Click" />
                <MenuItem x:Name="MiningUndockingMenuItem" Header="Undocking" IsCheckable="True" Click="MiningUndockingMenuItem_Click" />
                <MenuItem x:Name="MiningEmptyOnUndockMenuItem" Header="SelectBeltAndWarp" IsCheckable="True" Click="MiningEmptyOnUndockMenuItem_Click" />
                <MenuItem x:Name="MiningApproachingAsteroidMenuItem" Header="ApproachingAsteroid" IsCheckable="True" Click="MiningApproachingAsteroidMenuItem_Click" />
                <MenuItem x:Name="MiningMiningMenuItem" Header="Mining" IsCheckable="True" Click="MiningMiningMenuItem_Click" />
                <MenuItem x:Name="MiningDockMenuItem" Header="Dock" IsCheckable="True" Click="MiningDockMenuItem_Click" />
                <MenuItem x:Name="MiningRecoveryMenuItem" Header="Recovery" IsCheckable="True" Click="MiningRecoveryMenuItem_Click" />
            </MenuItem>
        </Menu>
        <Button Grid.Row="1"
                x:Name="StartButton"
                Click="Automate_Click"
                Content="Start"
                Background="#FF2CB43A"
                FontWeight="Bold"
                Margin="0,8,0,0" />
    </Grid>
</Window>
